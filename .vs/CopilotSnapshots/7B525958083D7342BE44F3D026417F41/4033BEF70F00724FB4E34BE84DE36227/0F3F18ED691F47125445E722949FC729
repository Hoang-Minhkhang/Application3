		private void button30_Click(object sender, EventArgs e)
		{
			// Switch to the PrintPreview tab
			tabControl1.SelectedIndex = 6;

			try
			{
				// Ensure both picture boxes exist
				if (pictureBox3 == null || CuaSoIn == null)
				{
					MessageBox.Show("Không tìm thấy điều khiển ảnh.", "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
					return;
				}

				// If there is an image in pictureBox3, clone it into CuaSoIn to avoid shared references
				if (pictureBox3.Image != null)
				{
					Image previous = CuaSoIn.Image;
					Image newImage = null;

					try
					{
						// Create the new image first. If this throws, we must NOT dispose the previous image.
						newImage = new Bitmap(pictureBox3.Image);

						// Assign the newly created image to the PictureBox
						CuaSoIn.Image = newImage;
						CuaSoIn.SizeMode = PictureBoxSizeMode.Zoom;

						// Prevent disposing the newly assigned image in the finally block
						newImage = null;
					}
					finally
					{
						// Dispose the previous image if it existed
						previous?.Dispose();

						// If newImage is not null here, it means creation succeeded but assignment didn't occur;
						// dispose it to avoid leaking the bitmap.
						newImage?.Dispose();
					}
				}
				else
				{
					MessageBox.Show("Không có ảnh trong pictureBox3 để hiển thị.", "Print Preview", MessageBoxButtons.OK, MessageBoxIcon.Information);
				}
			}
			catch (Exception ex)
			{
				MessageBox.Show("Lỗi khi sao chép ảnh: " + ex.Message, "Lỗi", MessageBoxButtons.OK, MessageBoxIcon.Error);
			}
		}
	}

