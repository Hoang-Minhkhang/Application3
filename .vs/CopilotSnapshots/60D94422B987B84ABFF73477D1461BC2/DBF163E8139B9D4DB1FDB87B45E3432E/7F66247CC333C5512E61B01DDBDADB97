		// ================== PHẦN TÁC VỤ ==================

		// Thêm tác vụ
		private void buttonThemTacVu_Click(object sender, EventArgs e)
		{
			TaskItem newTask = new TaskItem
			{
				Stt = tasks.Count + 1,
				Ten = textBoxTen.Text,
				ThoiGianHoanThanh = dateTimePickerNgay.Value.Date.Add(dateTimePickerGio.Value.TimeOfDay),
				QuanTrong = checkBoxQuanTrong.Checked,
				LinhVuc = textBoxLinhVuc.Text,
				NoiDung = textBoxNoiDung.Text
			};

			tasks.Add(newTask);
		}

		// Lưu (xuất ra file TXT)
		private void buttonLuu_Click(object sender, EventArgs e)
		{
			using (StreamWriter sw = new StreamWriter("tasks.txt"))
			{
				foreach (var task in tasks)
				{
					sw.WriteLine($"{task.Stt}\t{task.Ten}\t{task.ThoiGianHoanThanh}\t{task.QuanTrong}\t{task.LinhVuc}\t{task.NoiDung}");
				}
			}
			MessageBox.Show("Đã lưu tác vụ vào file tasks.txt");
		}

		// Import (nhập từ file TXT)
		private void buttonImportTask_Click(object sender, EventArgs e)
		{
			if (File.Exists("tasks.txt"))
			{
				tasks.Clear();
				string[] lines = File.ReadAllLines("tasks.txt");
				foreach (string line in lines)
				{
					string[] parts = line.Split('\t');
					if (parts.Length >= 6)
					{
						tasks.Add(new TaskItem
						{
							Stt = int.Parse(parts[0]),
							Ten = parts[1],
							ThoiGianHoanThanh = DateTime.Parse(parts[2]),
							QuanTrong = bool.Parse(parts[3]),
							LinhVuc = parts[4],
							NoiDung = parts[5]
						});
					}
				}
				MessageBox.Show("Đã nhập tác vụ từ file tasks.txt");
			}
		}

		// Export (xuất ra file TXT)
		private void buttonExportTask_Click(object sender, EventArgs e)
		{
			using (StreamWriter sw = new StreamWriter("tasks.txt"))
			{
				foreach (var task in tasks)
				{
					sw.WriteLine($"{task.Stt}\t{task.Ten}\t{task.ThoiGianHoanThanh}\t{task.QuanTrong}\t{task.LinhVuc}\t{task.NoiDung}");
				}
			}
			MessageBox.Show("Đã xuất tác vụ ra file tasks.txt");
		}

		// Xóa tác vụ
		private void buttonXoaTacVu_Click(object sender, EventArgs e)
		{
			if (dgvAllTasks.CurrentRow != null)
			{
				TaskItem selectedTask = dgvAllTasks.CurrentRow.DataBoundItem as TaskItem;
				if (selectedTask != null)
				{
					tasks.Remove(selectedTask);

					// Đánh lại số thứ tự
					int stt = 1;
					foreach (var task in tasks)
					{
						task.Stt = stt++;
					}
					dgvAllTasks.Refresh();
				}
			}
		}

